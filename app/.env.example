OPENWEATHER_API_KEY="..."
STATIC_GEO_URL="https://api.openweathermap.org/geo/1.0/direct"
STATIC_WEATHER_URL="https://api.openweathermap.org/data/2.5/weather"
STATIC_FORECAST_URL="https://api.openweathermap.org/data/2.5/forecast"
NOTES_DB_PATH="notes.db"
TASKS_DB_PATH="tasks.db"
TIMETRACKER_DB_PATH="timetracker.db"
REMINDERS_DB_PATH="reminders.db"
NEWSAPI_KEY="..."
NEWSAPI_URL="https://newsapi.org/v2/everything"

# Calendar provider: "google" or "outlook" (leave empty to disable calendar tools)
CALENDAR_PROVIDER=""

# Google Calendar (required if CALENDAR_PROVIDER=google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_TOKEN_PATH="google_token.json"

# Microsoft Outlook (required if CALENDAR_PROVIDER=outlook)
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""
MS_TENANT_ID="common"
MS_TOKEN_CACHE_PATH="ms_token_cache.json"
MS_GRAPH_URL="https://graph.microsoft.com/v1.0"

# Chat API (frontend backend) — uses OpenRouter
OPENROUTER_API_KEY="..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="anthropic/claude-sonnet-4"
CHAT_API_PORT="8001"

MCP_HOST="127.0.0.1"
MCP_PORT="8000"
